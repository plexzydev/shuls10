{
  "manifest_version": 3,
  "name": "Shuls - Kick Loyalty",
  "version": "1.0.0",
  "description": "Sistema de puntos y lealtad para el canal de Shuls en Kick",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": ["https://kick.com/*", "http://localhost:3001/*", "http://localhost:5173/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/logo.png",
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://kick.com/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://kick.com/*"]
    }
  ]
}
