# Server
PORT=3001
NODE_ENV=development

# JWT Secret (generar uno random)
JWT_SECRET=tu_secret_random_aqui

# Kick OAuth (de dev.kick.com)
KICK_CLIENT_ID=tu_kick_client_id
KICK_CLIENT_SECRET=tu_kick_client_secret
KICK_REDIRECT_URI=http://localhost:3001/auth/kick/callback
KICK_CHANNEL_SLUG=shuls10

# Twitch OAuth (para vincular cuentas)
TWITCH_CLIENT_ID=tu_twitch_client_id
TWITCH_CLIENT_SECRET=tu_twitch_client_secret
TWITCH_REDIRECT_URI=http://localhost:3001/auth/twitch/callback

# Discord OAuth & Bot (de discord.com/developers)
DISCORD_CLIENT_ID=tu_discord_client_id
DISCORD_CLIENT_SECRET=tu_discord_client_secret
DISCORD_BOT_TOKEN=tu_discord_bot_token
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL="file:./dev.db"
